{
  "name": "coltivio-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "cudba",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/agricoltivio/coltivio-api.git"
  },
  "scripts": {
    "compile": "tsc && yarn sentry:sourcemaps",
    "start": "ts-node src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "jest -i",
    "generate:api-types": "ts-node ./scripts/generate-openapi-docs.ts",
    "db:reset": "supabase db reset --no-seed && psql postgresql://postgres:postgres@127.0.0.1:54322/postgres -f scripts/setup-test-db.sql && yarn db:migrate && bash scripts/seed-auth.sh",
    "db:seed": "ts-node ./src/db/seed.ts",
    "db:push": "npx drizzle-kit push",
    "db:generate": "yarn drizzle-kit generate",
    "db:migrate": "yarn drizzle-kit migrate",
    "db:backup": "supabase db dump --data-only --exclude=public.federal_farm_plots -f backup_data_$(date +%Y%m%d).sql",
    "fix": "ts-node ./to_geojson.ts",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org agricoltivio --project node-express ./dist && sentry-cli sourcemaps upload --org agricoltivio --project node-express ./dist"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "@mapbox/geojson-area": "^0.2.2",
    "@nbelyh/exceljs": "^4.3.2",
    "@sentry/cli": "^3.1.0",
    "@sentry/node": "^10.34.0",
    "@supabase/supabase-js": "^2.90.1",
    "axios": "^1.9.0",
    "compression": "^1.8.0",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^1.0.0-beta.11",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-zod-api": "^26.3.1",
    "http-errors": "^2.0.0",
    "i18next": "^25.7.4",
    "i18next-http-middleware": "^3.9.2",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.17.1",
    "polylabel": "^2.0.1",
    "postgres": "^3.4.8",
    "shpjs": "^6.1.0",
    "stripe": "^20.4.1",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.4",
    "@types/jszip": "^3.4.1",
    "@types/lodash": "^4.17.23",
    "@types/mapbox__geojson-area": "^0.2.6",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/polylabel": "^1.1.3",
    "@types/shpjs": "^3.4.7",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "drizzle-kit": "^1.0.0-beta.11",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.0",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globalSetup": "./src/test/globalSetup.ts",
    "globalTeardown": "./src/test/globalTeardown.ts",
    "setupFiles": [
      "./src/test/setup.ts"
    ]
  }
}
