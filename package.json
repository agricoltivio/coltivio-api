    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
