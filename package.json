    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.9.0",
    "compression": "^1.8.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "drizzle-zod": "^0.7.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-zod-api": "^23.1.1",
    "http-errors": "^2.0.0",
    "i18next": "^25.0.1",
    "i18next-http-middleware": "^3.7.4",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "node-fetch": "^3.3.2",
    "pg": "^8.15.6",
    "polylabel": "^2.0.1",
    "postgres": "^3.4.5",
    "shpjs": "^6.1.0",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testcontainers/postgresql": "^10.24.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.1",
    "@types/http-errors": "^2.0.4",
    "@types/lodash": "^4.17.16",
    "@types/mapbox__geojson-area": "^0.2.6",
    "@types/node": "^20.17.31",
    "@types/pg": "^8.11.14",
    "@types/polylabel": "^1.1.3",
