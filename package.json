  "license": "ISC",
  "scripts": {
    "compile": "tsc && yarn sentry:sourcemaps",
    "start": "ts-node src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "jest -i",
    "generate:api-types": "ts-node ./scripts/generate-openapi-docs.ts",
    "db:seed": "ts-node ./src/db/seed.ts",
    "db:push": "npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "fix": "ts-node ./to_geojson.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org agricoltivio --project node-express ./dist && sentry-cli sourcemaps upload --org agricoltivio --project node-express ./dist"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.2.0",
    "@mapbox/geojson-area": "^0.2.2",
    "@nbelyh/exceljs": "^4.3.2",
    "@sentry/cli": "^2.43.0",
    "@sentry/node": "^9.12.0",
    "@supabase/supabase-js": "^2.46.2",
    "axios": "^1.8.4",
    "compression": "^1.8.0",
    "date-fns": "^3.1.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-zod-api": "^23.0.0",
    "http-errors": "^2.0.0",
    "i18next": "^24.2.3",
    "i18next-http-middleware": "^3.7.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "polylabel": "^1.1.0",
    "postgres": "^3.4.5",
    "shpjs": "^4.0.4",
    "ts-node": "^10.9.2",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testcontainers/postgresql": "^10.4.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/http-errors": "^2.0.4",
    "@types/lodash": "^4.14.202",
    "@types/mapbox__geojson-area": "^0.2.6",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.11.10",
    "@types/polylabel": "^1.1.3",
    "@types/shpjs": "^3.4.6",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.28.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supabase": "1.226.3",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globalSetup": "./src/jest.globalSetup.js",
    "globalTeardown": "./src/jest.globalTeardown.js"
  },
  "prisma": {
    "seed123": "node --max_old_space_size=8192 -r ts-node/register prisma/seed.ts",
    "seed": "ts-node prisma/seed.ts"
  }
}
