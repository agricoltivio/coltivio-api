  "scripts": {
    "compile": "tsc && yarn sentry:sourcemaps",
    "start": "ts-node src/index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "jest -i",
    "generate:api-types": "ts-node ./scripts/generate-openapi-docs.ts",
    "db:seed": "ts-node ./src/db/seed.ts",
    "db:push": "npx drizzle-kit push",
    "db:generate": "yarn drizzle-kit generate",
    "db:migrate": "yarn drizzle-kit migrate",
    "fix": "ts-node ./to_geojson.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org agricoltivio --project node-express ./dist && sentry-cli sourcemaps upload --org agricoltivio --project node-express ./dist"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.2.0",
    "@mapbox/geojson-area": "^0.2.2",
